# =========================================================
# نظام مصنع الزي الموحد — متغيرات البيئة (نموذج)
# انسخ هذا الملف إلى .env.local وعبّئ القيم.
# =========================================================

# ===== Supabase (يدعم Self-Hosted On-Premise) =====
# للنشر On-Premise: شغّل Supabase داخل الشبكة المحلية
# https://supabase.com/docs/guides/self-hosting
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# ⚠️ سرّي جدًا: لا تضفه أبدًا مع NEXT_PUBLIC_ ولا تستخدمه في الواجهة.
# مطلوب فقط لإجراءات السيرفر التي تعمل بدون جلسة Supabase مباشرة، مثل أزرار التابلت.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== التطبيق =====
NEXT_PUBLIC_APP_NAME="مصنع الزي الموحد"
NEXT_PUBLIC_APP_ENV=development

# ===== الأمان =====
# مدة جلسة التابلت بعد آخر نشاط (دقائق)
TABLET_SESSION_TIMEOUT_MIN=30
# سر توقيع جلسة التابلت. استخدم قيمة عشوائية طويلة في الإنتاج.
TABLET_SESSION_SECRET=replace-with-a-long-random-secret-at-least-24-chars
